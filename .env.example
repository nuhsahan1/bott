.env.example
# Database
DATABASE_URL=postgresql://postgres:password@postgres:5432/bott

# Redis
REDIS_URL=redis://redis:6379/0

# Service URLs
GATEWAY_URL=http://gateway:8000
REGISTRY_URL=http://registry:8001
FLOW_ENGINE_URL=http://flow-engine:8002
TEMPLATE_SERVICE_URL=http://template-service:8003
DISPATCHER_URL=http://dispatcher:8004
ANALYTICS_URL=http://analytics:8005
ADMIN_PANEL_URL=http://admin-panel:8006

# Logging
LOG_LEVEL=INFO

# Environment
ENV=development
DEBUG=true

# Telegram Bot Configuration (examples)
# TELEGRAM_BOT_TOKEN_1=YOUR_BOT_TOKEN_HERE
# TELEGRAM_BOT_NAME_1=MyAwesomeBot
